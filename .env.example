# Copy to .env and fill in values

# Path to model checkpoint for vllm serving
GRIDZERO_MODEL_PATH=./outputs/checkpoint-latest

# vllm server port
GRIDZERO_VLLM_PORT=8000

# vllm server URL (used by rollout client)
GRIDZERO_VLLM_URL=http://localhost:8000/v1

# Optional: Weights & Biases project
WANDB_PROJECT=gridzero
